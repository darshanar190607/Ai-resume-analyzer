{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "outDir": "dist-server",
    "allowJs": true,
    "resolveJsonModule": true,
    "types": ["node", "multer", "express"]
  },
  "include": ["server.ts", "models.ts"]
}
